# RAGBot configuration
#
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
#
# Switching providers is a single change to PROVIDER below. No secrets are
# committed; the default configuration runs the full ingest + retrieval
# pipeline for FREE using a local Ollama instance.

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# Which backend powers embeddings and answer generation.
#   none   -> no provider; embeddings & generation disabled (API still boots)
#   ollama -> local Ollama instance (free, default)
#   openai -> OpenAI API (requires OPENAI_API_KEY)
PROVIDER=none

# ---------------------------------------------------------------------------
# Ollama settings (used when PROVIDER=ollama)
# ---------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# ---------------------------------------------------------------------------
# OpenAI settings (used when PROVIDER=openai)
# ---------------------------------------------------------------------------
# Leave OPENAI_API_KEY empty unless PROVIDER=openai. Never commit a real key.
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Retrieval / chunking
# ---------------------------------------------------------------------------
# Character length of each text chunk and the overlap between consecutive
# chunks. TOP_K is the number of chunks retrieved per query.
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4

# Minimum top-source similarity (0..1) for an answer to count as well-grounded.
# When the best retrieved chunk scores below this, /ask declines to answer and
# returns status=insufficient_context (showing the closest related material)
# instead of grounding a reply on a weak match. Lower it if real questions are
# wrongly refused; raise it to be stricter. Tune to your embedding model.
GROUNDING_THRESHOLD=0.4

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Directory where ChromaDB persists vectors and where uploads are stored.
CHROMA_DIR=chroma_db
UPLOAD_DIR=uploads

# Maximum accepted upload size, in bytes (default 20 MB).
MAX_UPLOAD_SIZE_BYTES=20971520

# Maximum number of files accepted in one upload batch (e.g. a multi-file
# drag-and-drop in the UI). Each file is still sent as its own request; this
# just caps how many the client will fire off at once.
MAX_FILES_PER_REQUEST=20
